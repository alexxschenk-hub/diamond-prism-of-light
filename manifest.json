{
  "manifest_version": 3,
  "name": "DIAMOND – Prism of Light",
  "version": "1.0.0",
  "description": "Don't just see the news. See the spectrum. Spaltet Nachrichten in ihre manipulativen Farbkanäle auf.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["patterns.js", "analyzer.js", "essenz.js", "gefrierpunkt.js", "profiteur.js", "modulmanager.js", "sidebar.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
